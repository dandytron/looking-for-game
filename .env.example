# Copy to .env and fill in. .env is gitignored; .env.example is the committed template.

# Steam Web API key — register free at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Postgres (docker-compose) — used to initialise the DB on first boot
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# RabbitMQ (docker-compose) — login for AMQP (5672) + management UI (15672)
RABBITMQ_DEFAULT_USER=
RABBITMQ_DEFAULT_PASS=
